# Page Patrol now uses mode-specific environment files:
#
# Local (Caddy + localhost + Mailpit):
#   cp .env.local.example .env.local
#
# Production (Cloudflare Tunnel + custom domain + Resend SMTP):
#   cp .env.prod.example .env.prod
#
# Raspberry Pi production (env file lives outside the repo checkout):
#   ./scripts/pi-init-env.sh
#
# Keep this file as a pointer only.
