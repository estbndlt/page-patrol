# App
APP_DOMAIN=pagepatrol.example.com
APP_BASE_URL=https://pagepatrol.example.com
ACME_EMAIL=you@example.com
APP_LISTEN_ADDR=:8080
COOKIE_SECURE=true
SESSION_TTL=720h
MAGIC_LINK_TTL=15m
COORDINATOR_EMAIL=coordinator@example.com

# Database
DATABASE_URL=postgres://page_patrol:page_patrol@postgres:5432/page_patrol?sslmode=disable

# SMTP relay
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your-smtp-user
SMTP_PASS=your-smtp-password
SMTP_FROM_NAME=Page Patrol
SMTP_FROM_EMAIL=bookclub@example.com

# Optional: override default directories in container
# MIGRATIONS_DIR=/app/internal/db/migrations
# TEMPLATE_DIR=/app/web/templates
# STATIC_DIR=/app/web/static
