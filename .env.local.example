# Local development: Docker build + Caddy localhost + Mailpit SMTP
APP_DOMAIN=localhost
APP_BASE_URL=http://localhost:3000
ACME_EMAIL=dev@example.com
APP_LISTEN_ADDR=:8080
COOKIE_SECURE=false
SESSION_TTL=720h
MAGIC_LINK_TTL=15m
COORDINATOR_EMAIL=coordinator@example.com

# Database
DATABASE_URL=postgres://page_patrol:page_patrol@postgres:5432/page_patrol?sslmode=disable

# SMTP (Mailpit in docker-compose.local.yml)
SMTP_HOST=mailpit
SMTP_PORT=1025
SMTP_USER=
SMTP_PASS=
SMTP_FROM_NAME=Page Patrol
SMTP_FROM_EMAIL=bookclub@example.com
