# Local development: Docker build + Caddy localhost + Mailpit SMTP
APP_DOMAIN=localhost
APP_BASE_URL=http://localhost:3000
ACME_EMAIL=dev@example.com
APP_LISTEN_ADDR=:8080
COOKIE_SECURE=false
TRUST_PROXY_HEADERS=false
CSP_ALLOW_UNSAFE_INLINE=false
SESSION_TTL=720h
MAGIC_LINK_TTL=15m
MAGIC_LINK_RATE_LIMIT_WINDOW=15m
MAGIC_LINK_RATE_LIMIT_MAX_PER_IP=5
MAGIC_LINK_RATE_LIMIT_MAX_PER_EMAIL=3
MAGIC_LINK_RESEND_COOLDOWN=60s
COORDINATOR_EMAIL=coordinator@example.com

# Database
POSTGRES_DB=page_patrol
POSTGRES_USER=page_patrol
POSTGRES_PASSWORD=page_patrol_local_dev_only

# SMTP (Mailpit in docker-compose.local.yml)
SMTP_HOST=mailpit
SMTP_PORT=1025
SMTP_USER=
SMTP_PASS=
SMTP_FROM_NAME=Page Patrol
SMTP_FROM_EMAIL=bookclub@example.com
