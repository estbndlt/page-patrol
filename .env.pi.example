# Raspberry Pi production: keep the real env file outside the repo checkout.
# Default path used by scripts/pi-deploy.sh:
#   /home/estbndlt/.config/page-patrol/env.pi
APP_IMAGE=ghcr.io/YOUR_ORG/page-patrol
APP_TAG=main
TUNNEL_TOKEN=replace-with-cloudflare-tunnel-token

APP_BASE_URL=https://app.example.com
APP_LISTEN_ADDR=:8080
COOKIE_SECURE=true
TRUST_PROXY_HEADERS=true
SESSION_TTL=720h
MAGIC_LINK_TTL=15m
MAGIC_LINK_RATE_LIMIT_WINDOW=15m
MAGIC_LINK_RATE_LIMIT_MAX_PER_IP=5
MAGIC_LINK_RATE_LIMIT_MAX_PER_EMAIL=3
MAGIC_LINK_RESEND_COOLDOWN=60s
COORDINATOR_EMAIL=coordinator@example.com

# Database
POSTGRES_DB=page_patrol
POSTGRES_USER=page_patrol
POSTGRES_PASSWORD=replace-with-generated-password

# SMTP (Resend or another authenticated relay)
SMTP_HOST=smtp.resend.com
SMTP_PORT=587
SMTP_USER=resend
SMTP_PASS=re_replace_with_rotated_resend_api_key
SMTP_FROM_NAME=Page Patrol
SMTP_FROM_EMAIL=bookclub@example.com
