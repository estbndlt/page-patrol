# Production: pulled image + Cloudflare Tunnel + Resend SMTP
APP_IMAGE=ghcr.io/YOUR_ORG/page-patrol
APP_TAG=main
TUNNEL_TOKEN=replace-with-cloudflare-tunnel-token

APP_BASE_URL=https://app.example.com
APP_LISTEN_ADDR=:8080
COOKIE_SECURE=true
SESSION_TTL=720h
MAGIC_LINK_TTL=15m
COORDINATOR_EMAIL=coordinator@example.com

# Database
DATABASE_URL=postgres://page_patrol:page_patrol@postgres:5432/page_patrol?sslmode=disable

# SMTP (Resend)
SMTP_HOST=smtp.resend.com
SMTP_PORT=587
SMTP_USER=resend
SMTP_PASS=re_replace_with_resend_api_key
SMTP_FROM_NAME=Page Patrol
SMTP_FROM_EMAIL=bookclub@example.com
